# Port TCP microservice ini berjalan (harus sama dengan NOTIFICATION_SERVICE_PORT di backend)
PORT=3007

# SMTP — gunakan Mailtrap untuk development: https://mailtrap.io
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your_mailtrap_user
SMTP_PASS=your_mailtrap_pass
SMTP_FROM=noreply@dexa.com
